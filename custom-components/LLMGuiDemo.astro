---
import claudeIcon from "./media/claude.svg?url";
import codexIcon from "./media/codex.svg?url";
import geminiIcon from "./media/gemini.svg?url";
import genericIcon from "./media/generic.svg?url";
import mixedIcon from "./media/mixed.svg?url";

type DemoMode = "static" | "play" | "typing";
type DemoTheme = "light" | "dark" | "system";
type DemoApp = "workspace" | "generic";
type DemoProvider = "codex" | "claude" | "gemini" | "mixed" | "generic";
type DemoTone = "neutral" | "accent" | "success" | "warning" | "danger" | "muted";
type DemoRole = "user" | "assistant" | "tool" | "status" | "system" | "agent-event";
type DemoState = "idle" | "typing" | "running" | "done" | "error";
type DemoViewport = "mobile" | "tablet" | "desktop";
type DemoIconName =
	| "chevron-down"
	| "plus"
	| "home"
	| "external-link"
	| "clipboard"
	| "image"
	| "play"
	| "send"
	| "panel-left-open"
	| "panel-left-close"
	| "panel-right-open"
	| "panel-right-close"
	| "panel-bottom-open"
	| "panel-bottom-close"
	| "trash"
	| "message-square"
	| "settings";

interface DemoChip {
	label: string;
	tone?: DemoTone;
}

interface DemoCollapseBehavior {
	label?: string;
	defaultCollapsed?: boolean;
	byViewport?: Partial<Record<DemoViewport, boolean>>;
}

interface DemoAgent {
	id: string;
	label: string;
	provider?: DemoProvider;
	parentAgentId?: string;
}

interface DemoHeader {
	title: string;
	subtitle?: string;
	status?: DemoChip;
	statusLabel?: string;
	modelLabel?: string;
	appLabel?: string;
	providerLabel?: string;
	taskLabel?: string;
	breadcrumbs?: string[];
	contextLabel?: string;
	contextActionLabel?: string;
	primaryActionLabel?: string;
}

interface DemoTab {
	id: string;
	label: string;
	badge?: string;
}

interface DemoMarkdownishNodeParagraph {
	type: "p";
	text: string;
}

interface DemoMarkdownishNodeList {
	type: "ul" | "ol";
	items: string[];
}

type DemoMarkdownishNode = DemoMarkdownishNodeParagraph | DemoMarkdownishNodeList;

interface DemoTextBlock {
	type: "text";
	text: string;
	label?: string;
	tone?: DemoTone;
}

interface DemoMarkdownishBlock {
	type: "markdownish";
	label?: string;
	nodes: DemoMarkdownishNode[];
}

interface DemoCodeBlock {
	type: "code";
	code?: string;
	html?: string;
	language?: string;
	label?: string;
}

interface DemoKvListBlock {
	type: "kv-list";
	label?: string;
	items: Array<{ label: string; value: string }>;
}

interface DemoBadgeRowBlock {
	type: "badge-row";
	label?: string;
	items: Array<string | DemoChip>;
}

interface DemoFileListBlock {
	type: "file-list";
	label?: string;
	items: Array<{
		path: string;
		status?: string;
		delta?: string;
		tone?: DemoTone;
	}>;
}

interface DemoSummaryCardBlock {
	type: "summary-card";
	title: string;
	lines?: string[];
	tone?: DemoTone;
}

interface DemoTerminalSnippetBlock {
	type: "terminal-snippet";
	label?: string;
	prompt?: string;
	output?: string[];
}

type DemoBlock =
	| DemoTextBlock
	| DemoMarkdownishBlock
	| DemoCodeBlock
	| DemoKvListBlock
	| DemoBadgeRowBlock
	| DemoFileListBlock
	| DemoSummaryCardBlock
	| DemoTerminalSnippetBlock;

interface DemoMessageNode {
	type: "message";
	id: string;
	role: DemoRole;
	title?: string;
	state?: DemoState;
	agent?: DemoAgent;
	body?: DemoBlock[];
	meta?: Array<string | DemoChip>;
	collapsible?: DemoCollapseBehavior;
	tone?: DemoTone;
}

interface DemoGroupNode {
	type: "group";
	id: string;
	label: string;
	children: DemoNode[];
	defaultCollapsed?: boolean;
	collapse?: DemoCollapseBehavior;
	meta?: Array<string | DemoChip>;
	tone?: DemoTone;
}

type DemoNode = DemoMessageNode | DemoGroupNode;

interface DemoPaneTab {
	label: string;
	badge?: string;
	active?: boolean;
}

interface DemoPane {
	rightTitle?: string;
	rightSubtitle?: string;
	rightTabs?: DemoPaneTab[];
	right?: DemoBlock[];
	rightCollapse?: DemoCollapseBehavior;
	bottomTitle?: string;
	bottomTabs?: DemoPaneTab[];
	bottomActionLabel?: string;
	bottom?: DemoBlock[];
	bottomCollapse?: DemoCollapseBehavior;
}

interface DemoSidebarItem {
	label: string;
	subtitle?: string;
	meta?: string;
	delta?: string;
	tone?: DemoTone;
	active?: boolean;
}

interface DemoSidebarSection {
	title: string;
	actionLabel?: string;
	items?: DemoSidebarItem[];
	collapse?: DemoCollapseBehavior;
}

interface DemoSidebar {
	homeLabel?: string;
	workspaceLabel?: string;
	sections?: DemoSidebarSection[];
	footerLabel?: string;
	footerActions?: string[];
	collapse?: DemoCollapseBehavior;
}

interface DemoComposer {
	modelLabel?: string;
	secondaryLabel?: string;
	value?: string;
	hint?: string;
	actions?: string[];
	submitLabel?: string;
	statusLabel?: string;
	collapse?: DemoCollapseBehavior;
}

interface DemoScene {
	header: DemoHeader;
	tabs: DemoTab[];
	panes?: Record<string, DemoPane>;
	messages: DemoNode[];
	sidebar?: DemoSidebar;
	composer?: DemoComposer;
}

interface Props {
	scene: DemoScene;
	mode?: DemoMode;
	theme?: DemoTheme;
	app?: DemoApp;
	provider?: DemoProvider;
	maxHeight?: string;
	initialTab?: string;
	instanceId?: string;
	class?: string;
	tokens?: Record<string, string>;
}

const {
	scene,
	mode = "static",
	theme = "system",
	app = "workspace",
	provider = "generic",
	maxHeight,
	initialTab,
	instanceId,
	class: className = "",
	tokens = {},
} = Astro.props as Props;

if (!scene) {
	throw new Error("LLMGuiDemo requires a scene prop.");
}

const tabs = scene.tabs?.length ? scene.tabs : [{ id: "overview", label: "Overview" }];
const resolvedInitialTab = tabs.some((tab) => tab.id === initialTab) ? initialTab! : tabs[0].id;
const panes = scene.panes ?? {};
const hasRightPane = tabs.some(
	(tab) => (panes[tab.id]?.right?.length ?? 0) > 0 || (panes[tab.id]?.bottom?.length ?? 0) > 0,
);
const resolvedInstanceId =
	instanceId ?? `llm-gui-${Math.random().toString(36).slice(2)}-${Date.now().toString(36)}`;

const providerIcons: Record<DemoProvider, string> = {
	codex: codexIcon,
	claude: claudeIcon,
	gemini: geminiIcon,
	mixed: mixedIcon,
	generic: genericIcon,
};

function escapeHtml(value: string | undefined | null): string {
	return String(value ?? "")
		.replaceAll("&", "&amp;")
		.replaceAll("<", "&lt;")
		.replaceAll(">", "&gt;")
		.replaceAll('"', "&quot;")
		.replaceAll("'", "&#39;");
}

function escapeAttr(value: string | undefined | null): string {
	return escapeHtml(value).replaceAll("\n", "&#10;");
}

function escapeStyle(value: string | undefined | null): string {
	return escapeAttr(value).replaceAll(";", "");
}

function providerIconSrc(value?: DemoProvider) {
	return providerIcons[value ?? "generic"] ?? providerIcons.generic;
}

function renderIcon(name: DemoIconName, extraClass = "demo-icon") {
	const classAttr = escapeAttr(extraClass);
	const paths: Record<DemoIconName, string> = {
		"chevron-down": `<path d="M4.5 6.5 8 10l3.5-3.5" />`,
		plus: `<path d="M8 4.25v7.5" /><path d="M4.25 8h7.5" />`,
		home: `<path d="M3.75 7.25 8 4l4.25 3.25" /><path d="M5 6.5v5h6v-5" />`,
		"external-link": `<path d="M9.25 3.75h3v3" /><path d="M12.25 3.75 7.5 8.5" /><path d="M10.75 8.75v2.5a1 1 0 0 1-1 1h-5a1 1 0 0 1-1-1v-5a1 1 0 0 1 1-1h2.5" />`,
		clipboard: `<path d="M6 3.5h4" /><path d="M6.5 2.5h3a1 1 0 0 1 1 1v1h-5v-1a1 1 0 0 1 1-1Z" /><path d="M5 4.5H4.75A1.25 1.25 0 0 0 3.5 5.75v6.5A1.25 1.25 0 0 0 4.75 13.5h6.5a1.25 1.25 0 0 0 1.25-1.25v-6.5A1.25 1.25 0 0 0 11.25 4.5H11" />`,
		image: `<rect x="3" y="3.5" width="10" height="9" rx="1.25" /><circle cx="6.25" cy="6.25" r="1" /><path d="M4.75 10 7 7.75l1.75 1.75 1.25-1.25L11.75 10" />`,
		play: `<path d="M5.5 4.75v6.5L11 8z" />`,
		send: `<path d="m3.75 8 8-4-2 8-1.7-2.3z" /><path d="M10 4.75 8.05 9.7" />`,
		"panel-left-open": `<rect x="2.5" y="3" width="11" height="10" rx="1.5" /><path d="M6 3v10" /><path d="M9 6.25 11.5 8 9 9.75" />`,
		"panel-left-close": `<rect x="2.5" y="3" width="11" height="10" rx="1.5" /><path d="M6 3v10" /><path d="M10.5 6.25 8 8l2.5 1.75" />`,
		"panel-right-open": `<rect x="2.5" y="3" width="11" height="10" rx="1.5" /><path d="M10 3v10" /><path d="M7 6.25 4.5 8 7 9.75" />`,
		"panel-right-close": `<rect x="2.5" y="3" width="11" height="10" rx="1.5" /><path d="M10 3v10" /><path d="M5.5 6.25 8 8l-2.5 1.75" />`,
		"panel-bottom-open": `<rect x="2.5" y="2.5" width="11" height="11" rx="1.5" /><path d="M2.5 9.75h11" /><path d="M6.25 6.5 8 4.5l1.75 2" />`,
		"panel-bottom-close": `<rect x="2.5" y="2.5" width="11" height="11" rx="1.5" /><path d="M2.5 9.75h11" /><path d="M6.25 6.5 8 8.5l1.75-2" />`,
		trash: `<path d="M4.75 5.25v6" /><path d="M8 5.25v6" /><path d="M11.25 5.25v6" /><path d="M3.5 4h9" /><path d="M5.5 4V3h5v1" /><path d="M4.5 4.25v7.25c0 .55.45 1 1 1h5c.55 0 1-.45 1-1V4.25" />`,
		"message-square": `<path d="M3.5 4.25c0-.69.56-1.25 1.25-1.25h6.5c.69 0 1.25.56 1.25 1.25v4.5c0 .69-.56 1.25-1.25 1.25H7.5l-2.5 2v-2H4.75c-.69 0-1.25-.56-1.25-1.25z" />`,
		settings: `<circle cx="8" cy="8" r="1.8" /><path d="M8 3.5v1.1" /><path d="M8 11.4v1.1" /><path d="M11.18 4.82l-.78.78" /><path d="M5.6 10.4l-.78.78" /><path d="M12.5 8h-1.1" /><path d="M4.6 8H3.5" /><path d="M11.18 11.18l-.78-.78" /><path d="M5.6 5.6l-.78-.78" />`,
	};
	return `<svg class="${classAttr}" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">${paths[name]}</svg>`;
}

function slugify(value: string): string {
	return value
		.toLowerCase()
		.trim()
		.replace(/[^a-z0-9]+/g, "-")
		.replace(/^-+|-+$/g, "") || "item";
}

function toneValue(value?: DemoTone): DemoTone {
	return value ?? "neutral";
}

function normalizeChip(value: string | DemoChip): DemoChip {
	return typeof value === "string" ? { label: value, tone: "muted" } : value;
}

function renderChip(value: string | DemoChip, extraClass = ""): string {
	const chip = normalizeChip(value);
	const extra = extraClass ? ` ${extraClass}` : "";
	return `<span class="demo-chip${extra}" data-tone="${escapeAttr(toneValue(chip.tone))}">${escapeHtml(chip.label)}</span>`;
}

function collapsePanelId(nodeId: string) {
	return `${resolvedInstanceId}-${slugify(nodeId)}-panel`;
}

function collapseDataAttributes(config?: DemoCollapseBehavior) {
	if (!config) return "";
	const attrs = [
		` data-collapse-config="true"`,
		` data-collapse-default="${String(config.defaultCollapsed === true)}"`,
	];
	const mobile = config.byViewport?.mobile;
	const tablet = config.byViewport?.tablet;
	const desktop = config.byViewport?.desktop;
	if (typeof mobile === "boolean") attrs.push(` data-collapse-mobile="${String(mobile)}"`);
	if (typeof tablet === "boolean") attrs.push(` data-collapse-tablet="${String(tablet)}"`);
	if (typeof desktop === "boolean") attrs.push(` data-collapse-desktop="${String(desktop)}"`);
	return attrs.join("");
}

function collapseInitialHidden(config?: DemoCollapseBehavior, fallback = false) {
	return config?.defaultCollapsed === true || fallback;
}

function buildSequenceMap(nodes: DemoNode[]) {
	let sequence = 0;
	const map: Record<string, number> = {};

	const visit = (items: DemoNode[]) => {
		for (const item of items) {
			sequence += 1;
			map[item.id] = sequence;
			if (item.type === "group") {
				visit(item.children);
			}
		}
	};

	visit(nodes);
	return map;
}

const sequenceMap = buildSequenceMap(scene.messages);

function typingStyle(text: string, order: number): string {
	const duration = Math.min(3400, Math.max(700, text.length * 22));
	const steps = Math.min(72, Math.max(10, text.length));
	return `--typing-duration:${duration}ms;--typing-delay:${order * 120}ms;--typing-steps:${steps};`;
}

function renderAgent(agent?: DemoAgent): string {
	if (!agent) return "";
	const providerValue = agent.provider ?? "generic";
	const icon = providerIconSrc(providerValue);
	const providerLabel =
		agent.provider && agent.provider !== "generic" ? ` <span class="agent-pill__provider">${escapeHtml(agent.provider)}</span>` : "";
	return `<button class="agent-pill" type="button" data-provider="${escapeAttr(providerValue)}" data-tab-link="${escapeAttr(agent.id)}" aria-label="${escapeAttr(agent.label)}"><img class="agent-pill__icon" src="${escapeAttr(icon)}" alt="" loading="lazy" decoding="async" /><span class="agent-pill__label">${escapeHtml(agent.label)}</span>${providerLabel}</button>`;
}

function renderPaneTabs(items?: DemoPaneTab[]): string {
	if (!items?.length) return "";
	return `<div class="pane-tabs">${items
		.map((item) => {
			const badge = item.badge ? `<span class="pane-tabs__badge">${escapeHtml(item.badge)}</span>` : "";
			const label =
				item.label === "+"
					? `${renderIcon("plus", "pane-tab__icon")}<span class="visually-hidden">Add tab</span>`
					: `<span>${escapeHtml(item.label)}</span>`;
			return `<button class="pane-tab${item.active ? " is-active" : ""}" type="button" data-pane-tab aria-pressed="${item.active ? "true" : "false"}">${label}${badge}</button>`;
		})
		.join("")}</div>`;
}

function actionIconName(value: string): DemoIconName {
	const normalized = value.trim().toLowerCase();
	if (normalized.includes("clipboard") || normalized.includes("copy")) return "clipboard";
	if (normalized.includes("screenshot") || normalized.includes("image") || normalized.includes("gallery")) return "image";
	if (normalized.includes("run") || normalized.includes("publish") || normalized.includes("open")) return "play";
	return "plus";
}

function renderTextLines(text: string, typingEnabled: boolean, startOrder: number, tone?: DemoTone): string {
	return text
		.split("\n")
		.map((line, index) => {
			const safeLine = line.length ? line : " ";
			const styleAttr = typingEnabled ? ` style="${escapeStyle(typingStyle(safeLine, startOrder + index))}"` : "";
			const typingClass = typingEnabled ? "typing-track is-typing" : "typing-track";
			return `<p class="demo-paragraph" data-tone="${escapeAttr(toneValue(tone))}"><span class="${typingClass}"${styleAttr}>${escapeHtml(safeLine)}</span></p>`;
		})
		.join("");
}

function renderMarkdownish(nodes: DemoMarkdownishNode[], typingEnabled: boolean, startOrder: number): string {
	let order = startOrder;
	return nodes
		.map((node) => {
			if (node.type === "p") {
				const html = renderTextLines(node.text, typingEnabled, order);
				order += Math.max(1, node.text.split("\n").length);
				return `<div class="markdownish-block">${html}</div>`;
			}

			const tag = node.type === "ol" ? "ol" : "ul";
			const items = node.items
				.map((item, index) => {
					const styleAttr = typingEnabled
						? ` style="${escapeStyle(typingStyle(item, order + index))}"`
						: "";
					const typingClass = typingEnabled ? "typing-track is-typing" : "typing-track";
					return `<li><span class="${typingClass}"${styleAttr}>${escapeHtml(item)}</span></li>`;
				})
				.join("");
			order += Math.max(1, node.items.length);
			return `<${tag} class="markdownish-list">${items}</${tag}>`;
		})
		.join("");
}

function renderBlocks(blocks: DemoBlock[] | undefined, options: { typingEnabled?: boolean } = {}) {
	if (!blocks?.length) {
		return `<div class="empty-block">No content defined.</div>`;
	}

	const typingEnabled = options.typingEnabled === true;
	let order = 0;

	return blocks
		.map((block) => {
			const labelHtml = "label" in block && block.label ? `<div class="block-label">${escapeHtml(block.label)}</div>` : "";

			switch (block.type) {
				case "text": {
					const html = renderTextLines(block.text, typingEnabled, order, block.tone);
					order += Math.max(1, block.text.split("\n").length);
					return `<div class="demo-block block-text">${labelHtml}${html}</div>`;
				}
				case "markdownish": {
					const html = renderMarkdownish(block.nodes, typingEnabled, order);
					order += block.nodes.reduce((sum, node) => {
						return sum + (node.type === "p" ? Math.max(1, node.text.split("\n").length) : Math.max(1, node.items.length));
					}, 0);
					return `<div class="demo-block block-markdownish">${labelHtml}${html}</div>`;
				}
				case "code": {
					const language = block.language ? `<span class="code-language">${escapeHtml(block.language)}</span>` : "";
					if (block.html) {
						return `<div class="demo-block block-code">${labelHtml}<div class="code-shell code-shell--html">${language}<div class="code-html">${block.html}</div></div></div>`;
					}
					const code = block.code ?? "";
					const lines = code
						.split("\n")
						.map((line, index) => {
							const styleAttr = typingEnabled
								? ` style="${escapeStyle(typingStyle(line || " ", order + index))}"`
								: "";
							const typingClass = typingEnabled ? "typing-track is-typing" : "typing-track";
							return `<span class="code-line"><span class="${typingClass}"${styleAttr}>${escapeHtml(line || " ")}</span></span>`;
						})
						.join("");
					order += Math.max(1, code.split("\n").length);
					return `<div class="demo-block block-code">${labelHtml}<div class="code-shell">${language}<pre><code>${lines}</code></pre></div></div>`;
				}
				case "kv-list": {
					return `<div class="demo-block block-kv">${labelHtml}<dl class="kv-list">${block.items
						.map(
							(item) =>
								`<div class="kv-item"><dt>${escapeHtml(item.label)}</dt><dd>${escapeHtml(item.value)}</dd></div>`,
						)
						.join("")}</dl></div>`;
				}
				case "badge-row": {
					return `<div class="demo-block block-badge-row">${labelHtml}<div class="badge-row">${block.items
						.map((item) => renderChip(item))
						.join("")}</div></div>`;
				}
				case "file-list": {
					return `<div class="demo-block block-files">${labelHtml}<ul class="file-list">${block.items
						.map((item) => {
							const status = item.status ? `<span class="file-status">${escapeHtml(item.status)}</span>` : "";
							const delta = item.delta ? `<span class="file-delta">${escapeHtml(item.delta)}</span>` : "";
							return `<li class="file-item" data-tone="${escapeAttr(toneValue(item.tone))}"><span class="file-path">${escapeHtml(item.path)}</span><span class="file-meta">${status}${delta}</span></li>`;
						})
						.join("")}</ul></div>`;
				}
				case "summary-card": {
					return `<div class="demo-block block-summary" data-tone="${escapeAttr(toneValue(block.tone))}"><div class="summary-card"><h4>${escapeHtml(block.title)}</h4>${block.lines?.length ? `<ul class="summary-lines">${block.lines.map((line) => `<li>${escapeHtml(line)}</li>`).join("")}</ul>` : ""}</div></div>`;
				}
				case "terminal-snippet": {
					const prompt = block.prompt ? `<div class="terminal-prompt">${escapeHtml(block.prompt)}</div>` : "";
					const output = block.output?.length
						? block.output.map((line) => `<span class="terminal-line">${escapeHtml(line)}</span>`).join("")
						: `<span class="terminal-line terminal-line--muted">No output</span>`;
					return `<div class="demo-block block-terminal">${labelHtml}<div class="terminal-shell">${prompt}<div class="terminal-output">${output}</div></div></div>`;
				}
			}
		})
		.join("");
}

function renderMessage(node: DemoMessageNode, depth: number): string {
	const collapsible = !!node.collapsible;
	const collapsed = collapseInitialHidden(node.collapsible);
	const panelId = collapsePanelId(node.id);
	const revealAttr = mode === "play" ? ` data-reveal-seq="${sequenceMap[node.id] ?? 0}"` : "";
	const typingEnabled = (mode === "typing" || mode === "play") && node.state === "typing";
	return `<article class="message-card" data-role="${escapeAttr(node.role)}" data-state="${escapeAttr(node.state ?? "idle")}" data-tone="${escapeAttr(toneValue(node.tone))}" data-depth="${depth}"${revealAttr}>
		<div class="message-shell">
			<div class="message-topline">
				<div class="message-labels">
					${renderAgent(node.agent)}
					${node.title ? `<div class="message-title">${escapeHtml(node.title)}</div>` : ""}
				</div>
				${collapsible ? `<button class="collapse-toggle" type="button" data-collapse-button aria-expanded="${String(!collapsed)}" aria-controls="${escapeAttr(panelId)}">${escapeHtml(node.collapsible?.label ?? "Toggle details")}${renderIcon("chevron-down", "collapse-glyph")}</button>` : ""}
			</div>
			${node.meta?.length ? `<div class="message-meta">${node.meta.map((item) => renderChip(item)).join("")}</div>` : ""}
			<div class="message-body" id="${escapeAttr(panelId)}"${collapseDataAttributes(node.collapsible)}${collapsed ? " hidden" : ""}>${renderBlocks(node.body, { typingEnabled })}</div>
		</div>
	</article>`;
}

function renderGroup(node: DemoGroupNode, depth: number): string {
	const panelId = collapsePanelId(node.id);
	const collapseConfig = node.collapse ?? { defaultCollapsed: node.defaultCollapsed };
	const collapsed = collapseInitialHidden(collapseConfig, node.defaultCollapsed === true);
	const revealAttr = mode === "play" ? ` data-reveal-seq="${sequenceMap[node.id] ?? 0}"` : "";
	return `<section class="message-group" data-tone="${escapeAttr(toneValue(node.tone))}" data-depth="${depth}"${revealAttr}>
		<div class="message-group__header">
			<div class="message-group__title">
				<button class="collapse-toggle collapse-toggle--group" type="button" data-collapse-button aria-expanded="${String(!collapsed)}" aria-controls="${escapeAttr(panelId)}">${escapeHtml(collapseConfig.label ?? node.label)}${renderIcon("chevron-down", "collapse-glyph")}</button>
			</div>
			${node.meta?.length ? `<div class="message-group__meta">${node.meta.map((item) => renderChip(item)).join("")}</div>` : ""}
		</div>
		<div class="message-group__content" id="${escapeAttr(panelId)}"${collapseDataAttributes(collapseConfig)}${collapsed ? " hidden" : ""}>${renderNodes(node.children, depth + 1)}</div>
	</section>`;
}

function renderNodes(nodes: DemoNode[], depth = 0): string {
	return nodes.map((node) => (node.type === "group" ? renderGroup(node, depth) : renderMessage(node, depth))).join("");
}

function renderSidebar(sidebar?: DemoSidebar): string {
	const sections = sidebar?.sections?.length
		? sidebar.sections
		: [
				{
					title: "workspace",
					actionLabel: "+ New workspace",
					items: [{ label: scene.header.title, subtitle: scene.header.contextLabel, meta: scene.header.statusLabel, active: true }],
				},
			];
	const footerActions = sidebar?.footerActions?.length ? sidebar.footerActions : ["trash", "chat", "settings"];
	const footerIconMap: Record<string, DemoIconName> = {
		trash: "trash",
		chat: "message-square",
		settings: "settings",
	};
	const sidebarId = collapsePanelId("sidebar-root");
	const collapsed = collapseInitialHidden(sidebar?.collapse);
	return `<aside class="demo-sidebar" id="${escapeAttr(sidebarId)}" data-collapse-region="sidebar"${collapseDataAttributes(sidebar?.collapse)}${collapsed ? " hidden" : ""}>
		<div class="demo-sidebar__topbar">
			<div class="traffic-lights"><span class="traffic-light traffic-light--danger"></span><span class="traffic-light traffic-light--warning"></span><span class="traffic-light traffic-light--success"></span></div>
			<div class="window-actions"><span class="window-action"></span><span class="window-action"></span></div>
		</div>
		<button class="demo-sidebar__home" type="button" aria-label="${escapeAttr(sidebar?.homeLabel ?? "Home")}">${renderIcon("home", "sidebar-home__icon")}<span>${escapeHtml(sidebar?.homeLabel ?? "Home")}</span></button>
		<div class="demo-sidebar__scroll">
			${sections
				.map((section) => {
					const sectionPanelId = collapsePanelId(`sidebar-${section.title}`);
					const sectionCollapsed = collapseInitialHidden(section.collapse);
					const itemCount = section.items?.length
						? `<span class="sidebar-section__count">${escapeHtml(String(section.items.length))}</span>`
						: "";
					const disclosure = section.collapse
						? `<button class="sidebar-section__disclosure" type="button" data-collapse-button aria-expanded="${String(!sectionCollapsed)}" aria-controls="${escapeAttr(sectionPanelId)}"><span class="sidebar-section__disclosure-copy"><span class="sidebar-section__header">${escapeHtml(section.title)}</span>${itemCount}</span>${renderIcon("chevron-down", "collapse-glyph")}</button>`
						: `<div class="sidebar-section__disclosure is-static"><span class="sidebar-section__disclosure-copy"><span class="sidebar-section__header">${escapeHtml(section.title)}</span>${itemCount}</span></div>`;
					const items = section.items?.length
						? section.items
								.map((item) => {
										return `<button class="sidebar-item${item.active ? " is-active" : ""}" type="button" data-sidebar-item aria-pressed="${item.active ? "true" : "false"}">
											<div class="sidebar-item__copy">
												<div class="sidebar-item__title-row">
													<span class="sidebar-item__title">${escapeHtml(item.label)}</span>
													${item.delta ? `<span class="sidebar-item__delta" data-tone="${escapeAttr(toneValue(item.tone))}">${escapeHtml(item.delta)}</span>` : ""}
												</div>
												${item.subtitle ? `<div class="sidebar-item__subtitle">${escapeHtml(item.subtitle)}</div>` : ""}
											</div>
											${item.meta ? `<span class="sidebar-item__meta">${escapeHtml(item.meta)}</span>` : ""}
										</button>`;
									})
								.join("")
						: `<div class="sidebar-section__empty">No workspaces</div>`;
					return `<section class="sidebar-section">
						<div class="sidebar-section__header-row">
							${disclosure}
							${section.actionLabel ? `<button class="sidebar-section__action" type="button" aria-label="${escapeAttr(section.actionLabel)}" title="${escapeAttr(section.actionLabel)}">${renderIcon("plus", "sidebar-section__action-icon")}<span class="visually-hidden">${escapeHtml(section.actionLabel)}</span></button>` : ""}
						</div>
						<div class="sidebar-section__items" id="${escapeAttr(sectionPanelId)}"${collapseDataAttributes(section.collapse)}${sectionCollapsed ? " hidden" : ""}>${items}</div>
					</section>`;
				})
				.join("")}
		</div>
		<div class="demo-sidebar__footer">
			<button class="demo-sidebar__footer-label" type="button" aria-label="${escapeAttr(sidebar?.footerLabel ?? "Add source")}" title="${escapeAttr(sidebar?.footerLabel ?? "Add source")}">${renderIcon("plus", "footer-icon")}<span class="visually-hidden">${escapeHtml(sidebar?.footerLabel ?? "Add source")}</span></button>
			<div class="demo-sidebar__footer-actions">${footerActions
				.map((action) => `<button class="footer-action" type="button" aria-label="${escapeAttr(action)}" title="${escapeAttr(action)}">${renderIcon(footerIconMap[action] ?? "settings", "footer-icon")}</button>`)
				.join("")}</div>
		</div>
	</aside>`;
}

function renderPane(tab: DemoTab): string {
	const pane = panes[tab.id];
	const rightHtml = pane?.right?.length ? renderBlocks(pane.right) : `<div class="empty-pane">No contextual pane for this tab.</div>`;
	const bottomHtml = pane?.bottom?.length ? renderBlocks(pane.bottom) : "";
	const rightPanelId = collapsePanelId(`${tab.id}-right-pane`);
	const bottomPanelId = collapsePanelId(`${tab.id}-bottom-pane`);
	const rightCollapsed = collapseInitialHidden(pane?.rightCollapse);
	const bottomCollapsed = collapseInitialHidden(pane?.bottomCollapse);
	return `<section class="context-pane__panel" data-tab-panel="${escapeAttr(tab.id)}"${tab.id === resolvedInitialTab ? "" : " hidden"}>
		<div class="context-pane__top">
			<div class="context-pane__header">
				<div class="context-pane__copy">
					<h3>${escapeHtml(pane?.rightTitle ?? tab.label)}</h3>
					${pane?.rightSubtitle ? `<p>${escapeHtml(pane.rightSubtitle)}</p>` : ""}
				</div>
				<div class="context-pane__header-actions">
					${renderPaneTabs(pane?.rightTabs)}
					${pane?.rightCollapse ? `<button class="pane-toggle" type="button" data-collapse-button aria-expanded="${String(!rightCollapsed)}" aria-controls="${escapeAttr(rightPanelId)}" aria-label="${escapeAttr(pane.rightCollapse.label ?? "Toggle panel")}" title="${escapeAttr(pane.rightCollapse.label ?? "Toggle panel")}">${renderIcon(rightCollapsed ? "panel-right-open" : "panel-right-close", "pane-toggle__icon")}</button>` : ""}
				</div>
			</div>
			<div class="context-pane__body" id="${escapeAttr(rightPanelId)}"${collapseDataAttributes(pane?.rightCollapse)}${rightCollapsed ? " hidden" : ""}>${rightHtml}</div>
		</div>
		${bottomHtml ? `<div class="context-pane__bottom">
			<div class="context-pane__header context-pane__header--compact">
				<div class="context-pane__copy"><h4>${escapeHtml(pane?.bottomTitle ?? "Utility")}</h4></div>
				<div class="context-pane__header-actions">
					${renderPaneTabs(pane?.bottomTabs)}
					${pane?.bottomCollapse ? `<button class="pane-toggle" type="button" data-collapse-button aria-expanded="${String(!bottomCollapsed)}" aria-controls="${escapeAttr(bottomPanelId)}" aria-label="${escapeAttr(pane.bottomCollapse.label ?? "Toggle panel")}" title="${escapeAttr(pane.bottomCollapse.label ?? "Toggle panel")}">${renderIcon(bottomCollapsed ? "panel-bottom-open" : "panel-bottom-close", "pane-toggle__icon")}</button>` : ""}
					${pane?.bottomActionLabel ? `<button class="mini-action" type="button">${renderIcon(actionIconName(pane.bottomActionLabel), "mini-action__icon")}<span>${escapeHtml(pane.bottomActionLabel)}</span></button>` : ""}
				</div>
			</div>
			<div class="context-pane__body context-pane__body--bottom" id="${escapeAttr(bottomPanelId)}"${collapseDataAttributes(pane?.bottomCollapse)}${bottomCollapsed ? " hidden" : ""}>${bottomHtml}</div>
		</div>` : ""}
	</section>`;
}

function renderComposer(composer?: DemoComposer): string {
	if (!composer) return "";
	const panelId = collapsePanelId("composer");
	const collapsed = collapseInitialHidden(composer.collapse);
	return `<footer class="demo-composer">
		<div class="demo-composer__status">
			${composer.statusLabel ? `<span class="status-pill">${escapeHtml(composer.statusLabel)}</span>` : ""}
			<div class="demo-composer__actions">
				${composer.hint ? `<span class="composer-hint">${escapeHtml(composer.hint)}</span>` : ""}
				${composer.collapse ? `<button class="pane-toggle" type="button" data-collapse-button aria-expanded="${String(!collapsed)}" aria-controls="${escapeAttr(panelId)}" aria-label="${escapeAttr(composer.collapse.label ?? "Toggle composer")}" title="${escapeAttr(composer.collapse.label ?? "Toggle composer")}">${renderIcon(collapsed ? "panel-bottom-open" : "panel-bottom-close", "pane-toggle__icon")}</button>` : ""}
			</div>
		</div>
		<div class="composer-shell" id="${escapeAttr(panelId)}"${collapseDataAttributes(composer.collapse)}${collapsed ? " hidden" : ""}>
			<div class="composer-field">${escapeHtml(composer.value ?? "")}</div>
			<div class="composer-footer">
				<div class="composer-meta">
					${composer.modelLabel ? `<span class="composer-pill">${escapeHtml(composer.modelLabel)}</span>` : ""}
					${composer.secondaryLabel ? `<span class="composer-pill">${escapeHtml(composer.secondaryLabel)}</span>` : ""}
					${
						composer.actions?.length
							? `<div class="composer-actions">${composer.actions
									.map(
										(item) =>
											`<button class="composer-action" type="button" aria-label="${escapeAttr(item)}" title="${escapeAttr(item)}">${renderIcon(actionIconName(item), "composer-action__icon")}<span class="visually-hidden">${escapeHtml(item)}</span></button>`,
									)
									.join("")}</div>`
							: ""
					}
				</div>
				${
					composer.submitLabel
						? `<button class="composer-submit" type="button">${renderIcon("send", "composer-submit__icon")}<span>${escapeHtml(composer.submitLabel)}</span></button>`
						: ""
				}
			</div>
		</div>
	</footer>`;
}

const sidebarHtml = renderSidebar(scene.sidebar);
const transcriptHtml = renderNodes(scene.messages);
const paneHtml = tabs.map((tab) => renderPane(tab)).join("");
const composerHtml = renderComposer(scene.composer);
const topStatus = scene.header.status ? renderChip(scene.header.status, "is-status") : "";
const hasContextMeta = Boolean(scene.header.contextLabel || scene.header.contextActionLabel);
const hasStatusBar = Boolean(topStatus || scene.header.statusLabel || scene.header.taskLabel || scene.header.primaryActionLabel);
const providerIcon = providerIconSrc(provider);
const sidebarPanelId = collapsePanelId("sidebar-root");
const sidebarCollapsed = collapseInitialHidden(scene.sidebar?.collapse);
const themeTokenStyles = Object.entries(tokens)
	.map(([key, value]) => `${escapeStyle(key.startsWith("--") ? key : `--${key}`)}:${escapeStyle(value)}`)
	.join(";");

