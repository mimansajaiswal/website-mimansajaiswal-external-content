	.llm-gui-demo[data-mode="play"] [data-reveal-seq]{opacity:1;transform:none;}
}
`;

const styleTag = `<style>${rawCss}</style>`;
---

<div
	class:list={["llm-gui-demo", className]}
	data-llm-gui-demo
	data-instance-id={resolvedInstanceId}
	data-mode={mode}
data-theme-mode={theme}
data-app={app}
data-provider={provider}
data-active-tab={resolvedInitialTab}
data-has-right-pane={String(hasRightPane)}
style={`${maxHeight ? `--demo-max-height:${escapeStyle(maxHeight)};` : ""}${themeTokenStyles}`}
>
	<div aria-hidden="true" style="display:none" set:html={styleTag}></div>

	<div class="demo-shell">
		<div class="demo-shell__grid" data-sidebar-hidden={String(sidebarCollapsed)}>
			<div set:html={sidebarHtml}></div>

			<section class="demo-workbench">
				<header class="workbench-chrome">
						<div class="workbench-topbar">
							<div class="workbench-title">
								{scene.sidebar?.collapse ? (
									<button
										class="pane-visibility-toggle pane-visibility-toggle--sidebar"
										type="button"
										data-collapse-button
										aria-expanded={String(!sidebarCollapsed)}
										aria-controls={sidebarPanelId}
										aria-label={sidebarCollapsed ? "Show sidebar" : "Hide sidebar"}
										title={sidebarCollapsed ? "Show sidebar" : "Hide sidebar"}
									>
										<span class="visually-hidden">{sidebarCollapsed ? "Show sidebar" : "Hide sidebar"}</span>
										<div
											set:html={renderIcon(
												sidebarCollapsed ? "panel-left-open" : "panel-left-close",
												"pane-toggle__icon",
											)}
										/>
									</button>
								) : null}
								<span class="workbench-title__icon" aria-hidden="true"></span>
								<div class="workbench-title__copy">
									{scene.header.breadcrumbs?.length ? (
										<span class="workbench-title__eyebrow">{scene.header.breadcrumbs.join(" / ")}</span>
									) : null}
									<div class="workbench-title__mainline">
										<span class="workbench-title__text">{scene.header.title}</span>
										{scene.header.providerLabel ? (
											<span class="identity-pill identity-pill--provider">
												<img
													class="identity-pill__icon"
													src={providerIcon}
													alt=""
													loading="lazy"
													decoding="async"
												/>
												{scene.header.providerLabel}
											</span>
										) : null}
										{scene.header.modelLabel ? (
											<span class="identity-pill">{scene.header.modelLabel}</span>
										) : null}
									</div>
									{scene.header.subtitle ? (
										<p class="workbench-title__subtitle">{scene.header.subtitle}</p>
									) : null}
								</div>
						</div>

							{hasContextMeta ? (
								<div class="workbench-topbar__meta">
									{scene.header.contextLabel && <span class="context-pill">{scene.header.contextLabel}</span>}
									{scene.header.contextActionLabel && (
										<button
											class="pane-visibility-toggle"
											type="button"
											aria-label={scene.header.contextActionLabel}
											title={scene.header.contextActionLabel}
										>
											<span class="visually-hidden">{scene.header.contextActionLabel}</span>
											<div set:html={renderIcon("external-link", "pane-toggle__icon")} />
										</button>
									)}
								</div>
							) : null}

						{hasStatusBar ? (
							<div class="workbench-statusbar">
								<div class="workbench-statusbar__copy">
									{topStatus ? <div class="workbench-statusbar__chips" set:html={topStatus}></div> : null}
									{scene.header.statusLabel && <span class="workbench-statusbar__label">{scene.header.statusLabel}</span>}
									{scene.header.taskLabel && <span class="workbench-statusbar__meta">{scene.header.taskLabel}</span>}
								</div>
								{scene.header.primaryActionLabel && (
									<button class="primary-action" type="button">{scene.header.primaryActionLabel}</button>
								)}
							</div>
						) : null}
					</div>

					{tabs.length > 1 ? (
						<nav class="demo-tabs" aria-label="Demo tabs">
							{tabs.map((tab) => (
								<button
									class="demo-tab"
									type="button"
									data-tab-button
									data-tab-target={tab.id}
									aria-selected={tab.id === resolvedInitialTab}
								>
									{tab.label === "+" ? (
										<>
											<span class="visually-hidden">Add tab</span>
											<div set:html={renderIcon("plus", "demo-tab__icon")} />
										</>
									) : (
										<span>{tab.label}</span>
									)}
									{tab.badge && <span class="demo-tab__badge">{tab.badge}</span>}
								</button>
							))}
						</nav>
					) : null}
				</header>

				<div class="demo-main">
					<section class="transcript-panel">
						<div class="transcript-scroll" data-transcript-scroll set:html={transcriptHtml}></div>
						{composerHtml && <div set:html={composerHtml}></div>}
					</section>

					{hasRightPane && <aside class="context-pane" set:html={paneHtml}></aside>}
				</div>
			</section>
		</div>
	</div>
</div>

<script>
	(() => {
		const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

		const currentViewport = (root) => {
			const width = root.getBoundingClientRect().width;
			if (width <= 760) return "mobile";
			if (width <= 1080) return "tablet";
			return "desktop";
		};

		const setCollapseState = (root, panel, collapsed) => {
			panel.hidden = collapsed;
			if (panel.dataset.collapseRegion === "sidebar") {
				const grid = root.querySelector(".demo-shell__grid");
				if (grid instanceof HTMLElement) {
					grid.dataset.sidebarHidden = String(collapsed);
				}
			}
			const panelId = panel.id;
			if (!panelId) return;
			const button = root.querySelector(`[data-collapse-button][aria-controls="${CSS.escape(panelId)}"]`);
			if (button instanceof HTMLElement) {
				button.setAttribute("aria-expanded", collapsed ? "false" : "true");
			}
		};

		const applyResponsiveCollapse = (root, force = false) => {
			const viewport = currentViewport(root);
			root.querySelectorAll("[data-collapse-config]").forEach((panel) => {
				if (!(panel instanceof HTMLElement)) return;
				if (!force && panel.dataset.userToggled === "true") return;
				const viewportValue = panel.dataset[`collapse${viewport[0].toUpperCase()}${viewport.slice(1)}`];
				const shouldCollapse =
					typeof viewportValue === "string"
						? viewportValue === "true"
						: panel.dataset.collapseDefault === "true";
				setCollapseState(root, panel, shouldCollapse);
			});
		};

		const setActiveTab = (root, activeTab) => {
			root.dataset.activeTab = activeTab;
			root.querySelectorAll("[data-tab-button]").forEach((button) => {
				const isActive = button.getAttribute("data-tab-target") === activeTab;
				button.setAttribute("aria-selected", isActive ? "true" : "false");
			});
			root.querySelectorAll("[data-tab-panel]").forEach((panel) => {
				panel.hidden = panel.getAttribute("data-tab-panel") !== activeTab;
			});
		};

		const bindCollapseButtons = (root) => {
			root.querySelectorAll("[data-collapse-button]").forEach((button) => {
				if (button.dataset.bound === "true") return;
				button.dataset.bound = "true";
				button.addEventListener("click", () => {
					const targetId = button.getAttribute("aria-controls");
					if (!targetId) return;
					const panel = root.querySelector(`#${CSS.escape(targetId)}`);
					if (!(panel instanceof HTMLElement)) return;
					const expanded = button.getAttribute("aria-expanded") === "true";
					panel.dataset.userToggled = "true";
					setCollapseState(root, panel, expanded);
				});
			});
		};

		const bindTabs = (root) => {
			root.querySelectorAll("[data-tab-button]").forEach((button) => {
				if (button.dataset.bound === "true") return;
				button.dataset.bound = "true";
				button.addEventListener("click", () => {
					const target = button.getAttribute("data-tab-target");
					if (!target) return;
					setActiveTab(root, target);
				});
			});
		};

		const bindPaneTabs = (root) => {
			root.querySelectorAll("[data-pane-tab]").forEach((button) => {
				if (button.dataset.bound === "true") return;
				button.dataset.bound = "true";
				button.addEventListener("click", () => {
					const group = button.closest(".pane-tabs");
					if (!(group instanceof HTMLElement)) return;
					group.querySelectorAll("[data-pane-tab]").forEach((peer) => {
						peer.classList.remove("is-active");
						peer.setAttribute("aria-pressed", "false");
					});
					button.classList.add("is-active");
					button.setAttribute("aria-pressed", "true");
				});
			});
		};

		const bindSidebarItems = (root) => {
			root.querySelectorAll("[data-sidebar-item]").forEach((button) => {
				if (button.dataset.bound === "true") return;
				button.dataset.bound = "true";
				button.addEventListener("click", () => {
					const group = button.closest(".sidebar-section__items");
					if (!(group instanceof HTMLElement)) return;
					group.querySelectorAll("[data-sidebar-item]").forEach((peer) => {
						peer.classList.remove("is-active");
						peer.setAttribute("aria-pressed", "false");
					});
					button.classList.add("is-active");
					button.setAttribute("aria-pressed", "true");
				});
			});
		};

		const bindAgentLinks = (root) => {
			root.querySelectorAll("[data-tab-link]").forEach((button) => {
				if (button.dataset.bound === "true") return;
				button.dataset.bound = "true";
				button.addEventListener("click", () => {
					const target = button.getAttribute("data-tab-link");
					if (!target) return;
					const tab = root.querySelector(`[data-tab-button][data-tab-target="${CSS.escape(target)}"]`);
					if (tab instanceof HTMLElement) {
						setActiveTab(root, target);
					}
				});
			});
		};

		const runPlayMode = (root) => {
			if (root.dataset.mode !== "play" || root.dataset.playbound === "true") return;
			root.dataset.playbound = "true";
			const transcript = root.querySelector("[data-transcript-scroll]");
			const items = Array.from(root.querySelectorAll("[data-reveal-seq]")).sort((a, b) => {
				return Number(a.getAttribute("data-reveal-seq")) - Number(b.getAttribute("data-reveal-seq"));
			});
			if (prefersReducedMotion) {
				items.forEach((item) => item.classList.add("is-visible"));
				return;
			}
			items.forEach((item, index) => {
				window.setTimeout(() => {
					item.classList.add("is-visible");
					if (transcript instanceof HTMLElement) {
						transcript.scrollTo({ top: transcript.scrollHeight, behavior: "smooth" });
					}
				}, 180 + index * 140);
			});
		};

		const initRoot = (root) => {
			if (!(root instanceof HTMLElement) || root.dataset.initialized === "true") return;
			root.dataset.initialized = "true";
			const initialTab = root.dataset.activeTab;
			if (initialTab) setActiveTab(root, initialTab);
			bindTabs(root);
			bindPaneTabs(root);
			bindSidebarItems(root);
			bindAgentLinks(root);
			bindCollapseButtons(root);
			applyResponsiveCollapse(root, true);
			runPlayMode(root);

			if (!root.dataset.resizeBound) {
				root.dataset.resizeBound = "true";
				const observer = new ResizeObserver(() => applyResponsiveCollapse(root, false));
				observer.observe(root);
			}
		};

		const initAll = () => {
			document.querySelectorAll("[data-llm-gui-demo]").forEach((root) => initRoot(root));
		};

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", initAll, { once: true });
		} else {
			initAll();
		}
	})();
</script>
