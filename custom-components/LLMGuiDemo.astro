.llm-gui-demo .typing-track{display:inline-block;}
.llm-gui-demo .typing-track.is-typing{width:0;overflow:hidden;white-space:nowrap;animation:demo-typing var(--typing-duration) steps(var(--typing-steps)) var(--typing-delay) forwards;}
.llm-gui-demo [data-reveal-seq]{opacity:1;transform:none;}
.llm-gui-demo[data-mode="play"] [data-reveal-seq]{opacity:0;transform:translateY(12px);}
