.llm-gui-demo .demo-sidebar__home:hover,.llm-gui-demo .sidebar-section__disclosure:hover,.llm-gui-demo .sidebar-item:hover,.llm-gui-demo .demo-tab:hover,.llm-gui-demo .pane-tab:hover,.llm-gui-demo .agent-pill:hover,.llm-gui-demo .composer-action:hover,.llm-gui-demo .collapse-toggle:hover{color:var(--demo-text);}
.llm-gui-demo .sidebar-section__action:hover,.llm-gui-demo .demo-sidebar__footer-label:hover,.llm-gui-demo .footer-action:hover,.llm-gui-demo .pane-visibility-toggle:hover,.llm-gui-demo .pane-toggle:hover,.llm-gui-demo .composer-action:hover,.llm-gui-demo .composer-submit:hover,.llm-gui-demo .primary-action:hover,.llm-gui-demo .mini-action:hover{background:var(--demo-elevated);border-color:var(--demo-border-strong);color:var(--demo-text);}
.llm-gui-demo .demo-sidebar__home:focus-visible,.llm-gui-demo .sidebar-section__disclosure:focus-visible,.llm-gui-demo .sidebar-item:focus-visible,.llm-gui-demo .sidebar-section__action:focus-visible,.llm-gui-demo .demo-sidebar__footer-label:focus-visible,.llm-gui-demo .footer-action:focus-visible,.llm-gui-demo .pane-visibility-toggle:focus-visible,.llm-gui-demo .demo-tab:focus-visible,.llm-gui-demo .pane-tab:focus-visible,.llm-gui-demo .pane-toggle:focus-visible,.llm-gui-demo .collapse-toggle:focus-visible,.llm-gui-demo .agent-pill:focus-visible,.llm-gui-demo .composer-action:focus-visible,.llm-gui-demo .composer-submit:focus-visible,.llm-gui-demo .primary-action:focus-visible,.llm-gui-demo .mini-action:focus-visible{outline:2px solid color-mix(in srgb,var(--demo-accent) 80%,white);outline-offset:2px;}
